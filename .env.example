# MicroBreaks Environment Variables
# Copy to .env and fill in. Every variable here is actually read by the app,
# EAS, or the release validators — `npm run verify:config -- --profile production`
# tells you exactly what is still missing for a store build.

# ======================
# EAS (required for preview/production builds)
# ======================
# Run `npx eas-cli init` once; it prints the project id.
EAS_PROJECT_ID=
# Optional override — defaults to https://u.expo.dev/<EAS_PROJECT_ID>
EAS_UPDATE_URL=

# ======================
# Billing / RevenueCat (required for production)
# ======================
# Values: none | preview | revenuecat.
# eas.json already pins: development/preview → preview, production → revenuecat.
EXPO_PUBLIC_BILLING_PROVIDER=preview
# RevenueCat → Project → API keys (Apple/Google *public* SDK keys).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# ======================
# Firebase App Check (optional, debug builds only)
# ======================
# Debug token registered in Firebase Console → App Check → Manage debug tokens.
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# ======================
# Store submission (used by `eas submit`, see eas.json)
# ======================
APPLE_ID=
ASC_APP_ID=
APPLE_TEAM_ID=

# ======================
# File drops (not env vars — place these files at the repo root)
# ======================
# ./GoogleService-Info.plist   ← Firebase Console → iOS app config
# ./google-services.json       ← Firebase Console → Android app config
#   (paths overridable via GOOGLE_SERVICES_PLIST / GOOGLE_SERVICES_JSON)
# ./google-play-service-account.json ← Play Console service account key (eas submit)

# ======================
# App environment
# ======================
# Values: development | preview | production (eas.json sets this per profile)
APP_ENV=development
