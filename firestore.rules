rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function optionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function requiredString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function nonNegativeInt(value) {
      return value is int && value >= 0;
    }

    function positiveInt(value) {
      return value is int && value > 0;
    }

    function boundedInt(value, min, max) {
      return value is int && value >= min && value <= max;
    }

    function validProfile(profile) {
      return profile is map
        && profile.keys().hasOnly(['name', 'avatar', 'email', 'joinedAt', 'updatedAt'])
        && requiredString(profile.name, 80)
        && optionalString(profile.avatar, 512)
        && optionalString(profile.email, 254)
        && requiredString(profile.joinedAt, 64)
        && (!('updatedAt' in profile) || nonNegativeInt(profile.updatedAt));
    }

    function validProgress(progress) {
      return progress is map
        && progress.keys().hasOnly([
          'level',
          'totalXP',
          'totalBreaks',
          'currentStreak',
          'longestStreak',
          'weeklyGoal',
          'dailyGoal'
        ])
        && positiveInt(progress.level)
        && nonNegativeInt(progress.totalXP)
        && nonNegativeInt(progress.totalBreaks)
        && nonNegativeInt(progress.currentStreak)
        && nonNegativeInt(progress.longestStreak)
        && progress.longestStreak >= progress.currentStreak
        && boundedInt(progress.weeklyGoal, 1, 100)
        && boundedInt(progress.dailyGoal, 1, 20);
    }

    function validPreferences(preferences) {
      return preferences is map
        && preferences.keys().hasOnly(['favoriteBreaks', 'recentBreaks'])
        && preferences.favoriteBreaks is list
        && preferences.recentBreaks is list
        && preferences.favoriteBreaks.size() <= 100
        && preferences.recentBreaks.size() <= 25;
    }

    function validAchievements(achievements) {
      return achievements is map
        && achievements.keys().hasOnly(['unlockedIds', 'unlockedAt', 'categoryBreaks', 'totalMinutes'])
        && achievements.unlockedIds is list
        && achievements.unlockedIds.size() <= 200
        && achievements.unlockedAt is map
        && achievements.categoryBreaks is map
        && nonNegativeInt(achievements.totalMinutes);
    }

    function validSettings(settings) {
      return settings is map
        && settings.keys().hasOnly([
          'theme',
          'accentColor',
          'voiceGuidanceEnabled',
          'quietHoursEnabled',
          'quietHoursStart',
          'quietHoursEnd',
          'workDaysOnly',
          'workDays',
          'defaultBreakDuration',
          'autoStartNextStep',
          'showStepPreview',
          'updatedAt'
        ])
        && settings.theme in ['dark', 'light', 'system']
        && requiredString(settings.accentColor, 32)
        && settings.voiceGuidanceEnabled is bool
        && settings.quietHoursEnabled is bool
        && boundedInt(settings.quietHoursStart, 0, 23)
        && boundedInt(settings.quietHoursEnd, 0, 23)
        && settings.workDaysOnly is bool
        && settings.workDays is list
        && settings.workDays.size() <= 7
        && boundedInt(settings.defaultBreakDuration, 15, 600)
        && settings.autoStartNextStep is bool
        && settings.showStepPreview is bool
        && nonNegativeInt(settings.updatedAt);
    }

    function validLegacyPushFields(data) {
      return (!('fcmToken' in data) || optionalString(data.fcmToken, 4096))
        && (!('fcmTokenUpdatedAt' in data) || nonNegativeInt(data.fcmTokenUpdatedAt));
    }

    function validUserDoc(data) {
      return data.keys().hasOnly([
          'profile',
          'progress',
          'preferences',
          'achievements',
          'settings',
          'fcmToken',
          'fcmTokenUpdatedAt'
        ])
        && (!('profile' in data) || validProfile(data.profile))
        && (!('progress' in data) || validProgress(data.progress))
        && (!('preferences' in data) || validPreferences(data.preferences))
        && (!('achievements' in data) || validAchievements(data.achievements))
        && (!('settings' in data) || validSettings(data.settings))
        && validLegacyPushFields(data);
    }

    function validBreakDoc(docId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'breakId',
          'title',
          'category',
          'icon',
          'color',
          'duration',
          'stepsCompleted',
          'totalSteps',
          'xpEarned',
          'rating',
          'completedAt',
          'updatedAt'
        ])
        && request.resource.data.id == docId
        && requiredString(request.resource.data.id, 128)
        && requiredString(request.resource.data.breakId, 120)
        && requiredString(request.resource.data.title, 160)
        && request.resource.data.category in ['quick', 'stretch', 'mindful', 'active']
        && requiredString(request.resource.data.icon, 64)
        && requiredString(request.resource.data.color, 32)
        && boundedInt(request.resource.data.duration, 1, 600)
        && nonNegativeInt(request.resource.data.stepsCompleted)
        && positiveInt(request.resource.data.totalSteps)
        && request.resource.data.stepsCompleted <= request.resource.data.totalSteps
        && boundedInt(request.resource.data.xpEarned, 0, 1000)
        && (request.resource.data.rating == null
          || request.resource.data.rating in ['good', 'neutral', 'bad'])
        && requiredString(request.resource.data.completedAt, 64)
        && (!('updatedAt' in request.resource.data)
          || requiredString(request.resource.data.updatedAt, 64));
    }

    function validDeviceDoc(deviceId) {
      return request.resource.data.keys().hasOnly([
          'installationId',
          'token',
          'platform',
          'notificationsEnabled',
          'updatedAt'
        ])
        && request.resource.data.installationId == deviceId
        && (!('token' in request.resource.data) || requiredString(request.resource.data.token, 4096))
        && request.resource.data.platform in ['ios', 'android']
        && request.resource.data.notificationsEnabled is bool
        && (request.resource.data.notificationsEnabled == false
          || requiredString(request.resource.data.token, 4096))
        && nonNegativeInt(request.resource.data.updatedAt);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validUserDoc(request.resource.data);
      allow delete: if isOwner(userId);

      match /breaks/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validBreakDoc(docId);
        allow delete: if isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validDeviceDoc(deviceId);
        allow delete: if isOwner(userId);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
